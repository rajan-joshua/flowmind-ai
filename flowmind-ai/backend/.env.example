# Copy this file to .env and fill in your own keys.
# All three are optional — see "Live Data & Fallback Behavior" in the README
# for what happens when a key is missing (the app falls back to ML-predicted
# data from the trained engine, never random simulation).

# Required for the AI Assistant chat page (/assistant).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — enables real Google Maps Distance Matrix traffic data for
# corridor congestion on the Command Center / City Map. Without it, corridor
# congestion is predicted by the trained ML ensemble instead.
# Get one at https://console.cloud.google.com/ (enable Distance Matrix API)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional — enables real TomTom traffic incident data. Without it,
# incidents are sampled from real historical records and scored by the
# trained closure/congestion models for the current time of day.
# Get one at https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_api_key_here
